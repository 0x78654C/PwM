<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:PwM.Mobile.Pages"
       x:Class="PwM.Mobile.AppShell"
       Shell.NavBarIsVisible="True"
       Shell.TabBarIsVisible="True">

    <TabBar>
        <ShellContent Title="Vaults"
                      ContentTemplate="{DataTemplate pages:VaultListPage}"
                      Route="VaultListPage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x1F512;" Size="22" />
            </ShellContent.Icon>
        </ShellContent>
        <ShellContent Title="Settings"
                      ContentTemplate="{DataTemplate pages:SettingsPage}"
                      Route="SettingsPage">
            <ShellContent.Icon>
                <FontImageSource Glyph="&#x2699;" Size="22" />
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>
</Shell>
