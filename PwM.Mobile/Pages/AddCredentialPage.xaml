<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PwM.Mobile.ViewModels"
             x:Class="PwM.Mobile.Pages.AddCredentialPage"
             x:DataType="vm:AddCredentialViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Application / Site" Style="{StaticResource FieldLabel}" />
            <Entry Placeholder="e.g. GitHub" Text="{Binding Application}"
                   Style="{StaticResource EntryStyle}" />

            <Label Text="Account / Username" Style="{StaticResource FieldLabel}" />
            <Entry Placeholder="e.g. user@example.com" Text="{Binding Account}"
                   Style="{StaticResource EntryStyle}" />

            <Label Text="Password" Style="{StaticResource FieldLabel}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="Password"
                       Text="{Binding Password}"
                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                       Style="{StaticResource EntryStyle}" />
                <Button Grid.Column="1" Text="👁" FontSize="18"
                        BackgroundColor="Transparent" TextColor="{StaticResource AccentColor}"
                        Command="{Binding TogglePasswordVisibilityCommand}" />
            </Grid>

            <!-- Password generator -->
            <Border Padding="14" BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeShape="RoundRectangle 10" Stroke="{StaticResource BorderColor}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Password Generator" FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="Length:" VerticalOptions="Center"
                               TextColor="{StaticResource PrimaryTextColor}" />
                        <Slider Grid.Column="1" Minimum="12" Maximum="64"
                                Value="{Binding GeneratedLength}"
                                ThumbColor="{StaticResource AccentColor}"
                                MinimumTrackColor="{StaticResource AccentColor}" />
                    </Grid>
                    <Label Text="{Binding GeneratedLength, StringFormat='{0} characters'}"
                           FontSize="12" TextColor="{StaticResource SecondaryTextColor}"
                           HorizontalOptions="Center" />
                    <Button Text="⚡ Generate" Style="{StaticResource SecondaryButton}"
                            Command="{Binding GeneratePasswordCommand}" />
                </VerticalStackLayout>
            </Border>

            <!-- Breach check -->
            <Button Text="🔍 Check Breach (HIBP)" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CheckBreachCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            <Label Text="{Binding BreachWarning}" FontSize="13"
                   IsVisible="{Binding BreachWarning, Converter={StaticResource StringNotEmptyConverter}}"
                   HorizontalOptions="Center" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="{StaticResource AccentColor}" />

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,8,0,0">
                <Button Grid.Column="0" Text="Cancel" Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}" />
                <Button Grid.Column="1" Text="Save" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
