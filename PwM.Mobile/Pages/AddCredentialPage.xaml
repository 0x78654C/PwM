<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PwM.Mobile.ViewModels"
             x:Class="PwM.Mobile.Pages.AddCredentialPage"
             x:DataType="vm:AddCredentialViewModel"
             Title="{Binding Title}">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Style="{StaticResource PageContent}">
            <VerticalStackLayout Spacing="4">
                <Label Text="Add credential" Style="{StaticResource SectionTitle}" />
                <Label Text="Store a login in the currently unlocked vault."
                       Style="{StaticResource BodyText}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Application or site" Style="{StaticResource FieldLabel}" />
                <Entry Placeholder="e.g. GitHub"
                       Text="{Binding Application}"
                       ReturnType="Next"
                       Style="{StaticResource EntryStyle}" />

                <Label Text="Account or username" Style="{StaticResource FieldLabel}" />
                <Entry Placeholder="e.g. user@example.com"
                       Text="{Binding Account}"
                       ReturnType="Next"
                       Style="{StaticResource EntryStyle}" />

                <Label Text="Password" Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Password"
                           Text="{Binding Password}"
                           IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                           ReturnType="Done"
                           Style="{StaticResource EntryStyle}" />
                    <Button Grid.Column="1"
                            Text="{Binding PasswordVisibilityLabel}"
                            Style="{StaticResource IconButton}"
                            Command="{Binding TogglePasswordVisibilityCommand}" />
                </Grid>
            </VerticalStackLayout>

            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Password generator" Style="{StaticResource CardTitle}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Grid.Column="0"
                               Text="Length"
                               VerticalOptions="Center"
                               Style="{StaticResource BodyText}" />
                        <Slider Grid.Column="1"
                                Minimum="12"
                                Maximum="64"
                                Value="{Binding GeneratedLength}"
                                ThumbColor="{StaticResource AccentColor}"
                                MinimumTrackColor="{StaticResource AccentColor}" />
                    </Grid>
                    <Label Text="{Binding GeneratedLength, StringFormat='{0} characters'}"
                           HorizontalOptions="Center"
                           Style="{StaticResource BodyText}" />
                    <Button Text="Generate Password"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding GeneratePasswordCommand}" />
                </VerticalStackLayout>
            </Border>

            <Button Text="Check for Breaches"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CheckBreachCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
            <Label Text="{Binding BreachWarning}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource SecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}"
                   IsVisible="{Binding BreachWarning, Converter={StaticResource StringNotEmptyConverter}}"
                   HorizontalTextAlignment="Center" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource AccentColor}" />

            <VerticalStackLayout Spacing="10">
                <Button Text="Save Credential"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                <Button Text="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CancelCommand}" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
