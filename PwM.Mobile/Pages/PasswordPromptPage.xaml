<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PwM.Mobile.Pages.PasswordPromptPage"
             Shell.NavBarIsVisible="False">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Style="{StaticResource PageContent}"
                             VerticalOptions="Center">
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="14">
                    <Label x:Name="TitleLabel"
                           Style="{StaticResource SectionTitle}" />
                    <Label x:Name="MessageLabel"
                           Style="{StaticResource BodyText}" />
                    <Entry x:Name="PasswordEntry"
                           IsPassword="True"
                           ReturnType="Done"
                           Completed="OnSubmitClicked"
                           Style="{StaticResource EntryStyle}" />
                    <Label x:Name="ValidationLabel"
                           Text="Enter a password to continue."
                           TextColor="{StaticResource DangerColor}"
                           FontSize="12"
                           IsVisible="False" />
                    <Button Text="Continue"
                            Clicked="OnSubmitClicked"
                            Style="{StaticResource PrimaryButton}" />
                    <Button Text="Cancel"
                            Clicked="OnCancelClicked"
                            Style="{StaticResource SecondaryButton}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
