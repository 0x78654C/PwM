<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PwM.Mobile.ViewModels"
             x:Class="PwM.Mobile.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="⚙️ Settings" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryTextColor}" />

            <!-- Argon2 settings -->
            <Border Padding="16" BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderColor}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Argon2id Parameters" FontAttributes="Bold" FontSize="15"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Label Text="⚠️ Changing these affects all vaults. Re-create vaults to apply."
                           FontSize="12" TextColor="{StaticResource WarningColor}"
                           TextType="Html" />

                    <Label Text="Iterations (time cost)" Style="{StaticResource FieldLabel}" />
                    <Grid ColumnDefinitions="*,80" ColumnSpacing="8">
                        <Slider Grid.Column="0" Minimum="10" Maximum="200"
                                Value="{Binding Argon2Iterations}"
                                ThumbColor="{StaticResource AccentColor}"
                                MinimumTrackColor="{StaticResource AccentColor}" />
                        <Entry Grid.Column="1" Text="{Binding Argon2Iterations}"
                               Keyboard="Numeric" Style="{StaticResource EntryStyle}" />
                    </Grid>

                    <Label Text="Memory size (KB)" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding Argon2MemorySize}" Keyboard="Numeric"
                           Style="{StaticResource EntryStyle}" />

                    <Label Text="Parallelism (threads)" Style="{StaticResource FieldLabel}" />
                    <Grid ColumnDefinitions="*,80" ColumnSpacing="8">
                        <Slider Grid.Column="0" Minimum="1" Maximum="16"
                                Value="{Binding Argon2Parallelism}"
                                ThumbColor="{StaticResource AccentColor}"
                                MinimumTrackColor="{StaticResource AccentColor}" />
                        <Entry Grid.Column="1" Text="{Binding Argon2Parallelism}"
                               Keyboard="Numeric" Style="{StaticResource EntryStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Auto-lock -->
            <Border Padding="16" BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeShape="RoundRectangle 12" Stroke="{StaticResource BorderColor}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Auto-lock" FontAttributes="Bold" FontSize="15"
                           TextColor="{StaticResource PrimaryTextColor}" />
                    <Label Text="Minutes of inactivity before vault locks (0 = disabled)"
                           FontSize="12" TextColor="{StaticResource SecondaryTextColor}" />
                    <Grid ColumnDefinitions="*,80" ColumnSpacing="8">
                        <Slider Grid.Column="0" Minimum="0" Maximum="60"
                                Value="{Binding AutoLockMinutes}"
                                ThumbColor="{StaticResource AccentColor}"
                                MinimumTrackColor="{StaticResource AccentColor}" />
                        <Entry Grid.Column="1" Text="{Binding AutoLockMinutes}"
                               Keyboard="Numeric" Style="{StaticResource EntryStyle}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0" Text="Reset Defaults" Style="{StaticResource SecondaryButton}"
                        Command="{Binding ResetDefaultsCommand}" />
                <Button Grid.Column="1" Text="Save Settings" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
