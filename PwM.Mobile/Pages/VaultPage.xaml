<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PwM.Mobile.ViewModels"
             xmlns:model="clr-namespace:PwM.Mobile.Models"
             x:Class="PwM.Mobile.Pages.VaultPage"
             x:DataType="vm:VaultViewModel"
             Title="{Binding Title}">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="{Binding VaultName, StringFormat='🔓 {0}'}"
                   FontSize="18" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />
            <Button Grid.Column="1" Text="Lock" Style="{StaticResource DangerButton}"
                    Command="{Binding LockVaultCommand}" Margin="0,0,8,0" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12">

        <!-- Credential list -->
        <CollectionView Grid.Row="0" ItemsSource="{Binding Credentials}"
                        EmptyView="No credentials. Tap + to add one.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="model:CredentialEntry">
                    <SwipeView>
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Copy" BackgroundColor="{StaticResource AccentColor}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VaultViewModel}}, Path=CopyPasswordCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.LeftItems>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Update" BackgroundColor="{StaticResource WarningColor}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VaultViewModel}}, Path=UpdatePasswordCommand}"
                                           CommandParameter="{Binding .}" />
                                <SwipeItem Text="Delete" BackgroundColor="{StaticResource DangerColor}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VaultViewModel}}, Path=DeleteCredentialCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Margin="0,4" Padding="16,12"
                                BackgroundColor="{StaticResource SurfaceColor}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="{StaticResource BorderColor}">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding Application}" FontSize="15"
                                           FontAttributes="Bold" TextColor="{StaticResource PrimaryTextColor}" />
                                    <Label Text="{Binding Account}" FontSize="13"
                                           TextColor="{StaticResource SecondaryTextColor}" />
                                    <Label Text="⚠️ Breached password" FontSize="12"
                                           TextColor="{StaticResource DangerColor}"
                                           IsVisible="{Binding HasBreach}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="👁" FontSize="18"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource AccentColor}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:VaultViewModel}}, Path=ShowPasswordCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Action bar -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Button Grid.Column="0" Text="+ Add Credential" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddCredentialCommand}" />
            <Button Grid.Column="1" Text="⚙" FontSize="20"
                    BackgroundColor="Transparent" TextColor="{StaticResource AccentColor}"
                    Command="{Binding ChangeMasterPasswordCommand}" />
        </Grid>

    </Grid>
</ContentPage>
