<Window x:Class="PwM.AddApplications"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:adorners="http://gu.se/Adorners"
        mc:Ignorable="d"
        Title="PwM - Password Manager"
        Name="AddApplicationWPF"
        Icon="pack://application:,,,/Resources/logo-modern.ico"
        AllowsTransparency="True"
        Background="Transparent"
        Height="510"
        Width="480"
        ResizeMode="NoResize"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CredentialInputStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CredentialPasswordStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="78"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#0F172A" CornerRadius="13,13,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="64"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="48"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" Background="#4F46E5" CornerRadius="10" HorizontalAlignment="Right">
                        <materialDesign:PackIcon Kind="KeyPlus"
                                                 Width="21"
                                                 Height="21"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,16,0,0">
                        <TextBlock Text="Add credential" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="Save a new account in the active vault" Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="2"
                            Style="{DynamicResource TitleBarButtonBorder}"
                            ToolTip="Close"
                            PreviewMouseDown="closeLBL_PreviewMouseDown">
                        <materialDesign:PackIcon Name="vaultIcon"
                                                 Kind="Close"
                                                 Foreground="{DynamicResource TitleBarButtonForegroundBrush}"
                                                 Width="18"
                                                 Height="18"
                                                 IsHitTestVisible="False"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28,22,28,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Application" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox x:Name="appNameTXT"
                             Style="{StaticResource CredentialInputStyle}"
                             TextChanged="appNameTXT_TextChanged"
                             adorners:Watermark.Text="e.g. GitHub, Email, Banking">
                        <adorners:Watermark.TextStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="12,0,0,0"/>
                            </Style>
                        </adorners:Watermark.TextStyle>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Account" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox x:Name="accountNameTXT"
                             Style="{StaticResource CredentialInputStyle}"
                             TextChanged="accountNameTXT_TextChanged"
                             adorners:Watermark.Text="Username or email address">
                        <adorners:Watermark.TextStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="12,0,0,0"/>
                            </Style>
                        </adorners:Watermark.TextStyle>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Password" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="76"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Name="accPasswordBox"
                                     Style="{StaticResource CredentialPasswordStyle}"
                                     PasswordChanged="accPasswordBox_PasswordChanged"
                                     adorners:Watermark.Text="Account password">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </PasswordBox>
                        <TextBox x:Name="PasswordShow"
                                 Style="{StaticResource CredentialInputStyle}"
                                 Visibility="Hidden"
                                 TextChanged="accountNameTXT_TextChanged"
                                 adorners:Watermark.Text="Account password">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </TextBox>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Width="32" Height="42" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="7" Margin="6,0,4,0">
                                <materialDesign:PackIcon Name="GeneratePassAcc"
                                                         ToolTip="Generate strong password"
                                                         Foreground="#4F46E5"
                                                         Kind="AutoFix"
                                                         Width="17"
                                                         Height="17"
                                                         Cursor="Hand"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         PreviewMouseDown="GeneratePassAcc_PreviewMouseDown"/>
                            </Border>
                            <Border Width="32" Height="42" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="7">
                                <materialDesign:PackIcon Name="ShowPassword"
                                                         ToolTip="Hold right click to show password"
                                                         Foreground="#64748B"
                                                         Kind="EyeOutline"
                                                         Width="17"
                                                         Height="17"
                                                         Cursor="Hand"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         PreviewMouseRightButtonDown="ShowHidePassword"
                                                         PreviewMouseRightButtonUp="ShowHidePassword"
                                                         PreviewMouseMove="ShowPassword_PreviewMouseMove"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="5" Margin="0,10,0,0" Background="#FEF2F2" CornerRadius="7" Padding="10,7">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Visibility, ElementName=breachLbl}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#DC2626" Width="16" Height="16" Margin="0,0,7,0"/>
                        <TextBlock Name="breachLbl"
                                   Visibility="Hidden"
                                   Text="This password appears in an exposed data breach."
                                   Foreground="#B91C1C"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="7">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ShieldCheckOutline" Foreground="#16A34A" Width="16" Height="16" Margin="0,0,6,0"/>
                        <TextBlock Text="Encrypted before storage" Foreground="#64748B" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Name="addAppBTN"
                            Style="{DynamicResource RoundCorner2}"
                            Content="Add credential"
                            Width="128"
                            Height="38"
                            HorizontalAlignment="Right"
                            Click="addAppBTN_Click"
                            IsEnabled="False"
                            IsDefault="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
