<Window x:Class="PwM.ImportNotification" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PwM - Password Manager" Icon="pack://application:,,,/Resources/logo-modern.ico" AllowsTransparency="True" Background="Transparent" Height="300" Width="440" ResizeMode="NoResize" WindowStyle="None" WindowStartupLocation="CenterScreen">
    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/></Border.Effect>
        <Grid><Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="#0F172A" CornerRadius="13,13,0,0"><TextBlock Text="Replace existing vault" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="22,0" VerticalAlignment="Center"/></Border>
            <Grid Grid.Row="1" Margin="24,20"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"><Border Width="42" Height="42" Background="#FFFBEB" CornerRadius="10" Margin="0,0,14,0"><materialDesign:PackIcon Kind="FileReplaceOutline" Foreground="#D97706" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><TextBlock Name="notificationLBL" Text="notificationArea" Foreground="#334155" FontSize="13" TextWrapping="Wrap" Width="310" VerticalAlignment="Center"/></StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"><Button Name="cancelBTN" Style="{DynamicResource SecondaryButton}" Content="Cancel" Width="96" Margin="0,0,8,0" Click="CancelBTN_Click"/><Button Name="confirmBTN" Style="{DynamicResource RoundCorner2}" Content="Replace" Width="96" Click="confirmBTN_Click" IsDefault="True"/></StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
