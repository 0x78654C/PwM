<Window x:Class="PwM.ImportShared" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PwM - Password Manager" Icon="pack://application:,,,/Resources/logo-modern.ico" AllowsTransparency="True" Background="Transparent" Height="340" Width="480" ResizeMode="NoResize" WindowStyle="None" WindowStartupLocation="CenterScreen">
    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/></Border.Effect>
        <Grid><Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="#0F172A" CornerRadius="13,13,0,0"><Grid><TextBlock Text="Import vault" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="22,0" VerticalAlignment="Center"/><materialDesign:PackIcon Kind="Close" Foreground="#CBD5E1" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,20,0" Cursor="Hand" PreviewMouseDown="CloseLbl_PreviewMouseDown"/></Grid></Border>
            <Grid Grid.Row="1" Margin="24,20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock Name="notificationLBL" Text="Choose how this vault should be imported." Foreground="#475569" FontSize="13" TextWrapping="Wrap"/>
                <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Button Name="LocalBtn" Style="{DynamicResource SecondaryButton}" Click="LocalBtn_Click" IsDefault="True"><StackPanel><materialDesign:PackIcon Kind="Harddisk" Foreground="#4F46E5" Width="28" Height="28" HorizontalAlignment="Center" Margin="0,6,0,8"/><TextBlock Text="Local vault" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Copy into this device" Foreground="#64748B" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,6"/></StackPanel></Button>
                    <Button Grid.Column="2" Name="SharedBtn" Style="{DynamicResource SecondaryButton}" Click="SharedBtn_Click"><StackPanel><materialDesign:PackIcon Kind="AccountMultipleOutline" Foreground="#4F46E5" Width="28" Height="28" HorizontalAlignment="Center" Margin="0,6,0,8"/><TextBlock Text="Shared vault" FontWeight="SemiBold" HorizontalAlignment="Center"/><TextBlock Text="Use from its current path" Foreground="#64748B" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,6"/></StackPanel></Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
