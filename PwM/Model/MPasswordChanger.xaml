<Window x:Class="PwM.MPasswordChanger"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:adorners="http://gu.se/Adorners"
        Title="PwM - Password Manager"
        Icon="pack://application:,,,/Resources/logo-modern.ico"
        AllowsTransparency="True"
        Background="Transparent"
        Height="520"
        Width="440"
        ResizeMode="NoResize"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="MasterPasswordInputStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="MasterPasswordFieldStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#0F172A" CornerRadius="13,13,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" Background="#4F46E5" CornerRadius="9" HorizontalAlignment="Right">
                        <materialDesign:PackIcon Kind="ShieldKey"
                                                 Width="19"
                                                 Height="19"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,14,0,0">
                        <TextBlock Text="Change master password" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Update the key that protects this vault" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="2"
                            Style="{DynamicResource TitleBarButtonBorder}"
                            ToolTip="Close"
                            PreviewMouseDown="closeLBL_PreviewMouseDown">
                        <materialDesign:PackIcon Kind="Close"
                                                 Foreground="{DynamicResource TitleBarButtonForegroundBrush}"
                                                 Width="18"
                                                 Height="18"
                                                 IsHitTestVisible="False"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="9" Padding="12,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="SafeSquareOutline" Width="18" Height="18" Foreground="#4F46E5" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Vault: " Foreground="#64748B" FontSize="11"/>
                            <TextBlock Name="vaultNameTB" Text="name" Foreground="#0F172A" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Current master password" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <PasswordBox Name="OldMasterPassword"
                                     Style="{StaticResource MasterPasswordFieldStyle}"
                                     PasswordChanged="OldMasterPassword_PasswordChanged"
                                     adorners:Watermark.Text="Enter your current master password">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </PasswordBox>
                        <TextBox Name="OldMasterPasswordTXT"
                                 Style="{StaticResource MasterPasswordInputStyle}"
                                 Visibility="Hidden"
                                 adorners:Watermark.Text="Enter your current master password"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="New master password" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <PasswordBox Name="NewMasterPassword"
                                     Style="{StaticResource MasterPasswordFieldStyle}"
                                     PasswordChanged="addVPassword_PasswordChanged"
                                     adorners:Watermark.Text="At least 12 characters">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </PasswordBox>
                        <TextBox Name="NewMasterPassTXT"
                                 Style="{StaticResource MasterPasswordInputStyle}"
                                 Visibility="Hidden"
                                 adorners:Watermark.Text="At least 12 characters"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="6">
                    <TextBlock Text="Confirm new master password" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="34"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Name="ConfirmNewMasterPassword"
                                     Style="{StaticResource MasterPasswordFieldStyle}"
                                     PasswordChanged="confirmVPassword_PasswordChanged"
                                     adorners:Watermark.Text="Re-enter the new master password">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </PasswordBox>
                        <TextBox Name="ConfirmNewMasterPassTXT"
                                 Style="{StaticResource MasterPasswordInputStyle}"
                                 Visibility="Hidden"
                                 adorners:Watermark.Text="Re-enter the new master password"/>
                        <materialDesign:PackIcon Grid.Column="1"
                                                 Name="ShowNewVaultPassword"
                                                 Kind="EyeOutline"
                                                 Foreground="#64748B"
                                                 Width="18"
                                                 Height="18"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Cursor="Hand"
                                                 ToolTip="Hold right click to show passwords"
                                                 PreviewMouseRightButtonDown="ShowVaultPassword"
                                                 PreviewMouseRightButtonUp="ShowVaultPassword"
                                                 PreviewMouseMove="ShowNewVaultPassword_PreviewMouseMove"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="8" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" Foreground="#64748B" Width="15" Height="15" Margin="0,0,6,0"/>
                    <TextBlock Text="Use 12 or more characters for the new password." Foreground="#64748B" FontSize="10" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="10">
                    <TextBlock Text="All vault credentials will be re-encrypted." Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                    <Button Name="createBTN"
                            Style="{DynamicResource RoundCorner2}"
                            Content="Change password"
                            Width="140"
                            Height="38"
                            HorizontalAlignment="Right"
                            Click="saveBTN_Click"
                            IsEnabled="False"
                            IsDefault="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
