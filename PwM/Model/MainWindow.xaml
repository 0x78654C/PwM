<Window x:Class="PwM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:adorners="http://gu.se/Adorners"
        mc:Ignorable="d"
        Name="Pwm"
        Title="PwM"
        Icon="pack://application:,,,/Resources/logo-modern.ico"
        Height="720"
        Width="1120"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Closing="Pwm_Closing">
    <Window.Resources>
        <Style x:Key="NavItemStyle" TargetType="{x:Type ListViewItem}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="12,3"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarNavTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="NavBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource SidebarNavSelectionBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarNavSelectedTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource SidebarNavSelectionBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarNavSelectedTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="NavBorder" Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource SidebarNavDisabledTextBrush}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridViewColumnHeaderStyle1" TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="DataListStyle" TargetType="{x:Type ListView}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="MinHeight" Value="44"/>
                        <Setter Property="Padding" Value="16,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceHoverBrush}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListViewItem}">
                                    <Border x:Name="RowBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <GridViewRowPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="RowBorder" Property="Background" Value="#4F46E5"/>
                                            <Setter TargetName="RowBorder" Property="BorderBrush" Value="#4338CA"/>
                                            <Setter TargetName="RowBorder" Property="BorderThickness" Value="4,0,0,1"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionBorderStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="11,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="ModernContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.18" Color="#0F172A"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="230"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="MenuItemBorder"
                                Margin="0,1"
                                Padding="10,0"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter ContentSource="Icon"
                                                  Width="17"
                                                  Height="17"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#4F46E5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDangerMenuItemStyle"
               TargetType="{x:Type MenuItem}"
               BasedOn="{StaticResource ModernMenuItemStyle}">
            <Setter Property="Foreground" Value="#DC2626"/>
        </Style>

        <Style x:Key="ModernMenuSeparatorStyle" TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="10,5"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="1" Background="{DynamicResource BorderBrush}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsInputStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SettingsComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource AccentSurfaceBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Path Data="M 0 0 L 4 4 L 8 0"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="1.5"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Margin="0,4,0,0"
                                        Padding="4"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupMenuButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="PopupButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PopupButtonBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupDangerButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource PopupMenuButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="Transparent"
            CornerRadius="16"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.22" Color="#0F172A"/>
        </Border.Effect>
        <Grid x:Name="mainInnerGrid" SizeChanged="MainInnerGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="68"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="GridMenu"
                    Grid.RowSpan="2"
                    Background="{StaticResource SidebarBrush}"
                    CornerRadius="16,0,0,16"
                    SizeChanged="RoundedBorder_SizeChanged">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="88"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="22,22,18,18">
                    <Image Source="pack://application:,,,/Resources/logo-modern.png"
                           Width="44"
                           Height="44"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                    <StackPanel Margin="12,1,0,0">
                        <TextBlock Text="PwM" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="Password Manager" Foreground="#94A3B8" FontSize="11" Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="WORKSPACE"
                               Foreground="#64748B"
                               FontSize="10"
                               FontWeight="Bold"
                               Margin="26,8,0,8"/>
                    <ListViewItem Name="vaultsListVI"
                                  Style="{StaticResource NavItemStyle}"
                                  ToolTip="Vaults"
                                  PreviewMouseDown="Vault_PreviewMouseDown">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Name="vaultIcon"
                                                     Kind="SafeSquareOutline"
                                                     Tag="PreserveThemeForeground"
                                                     Foreground="{DynamicResource SidebarNavSelectedTextBrush}"
                                                     Width="20"
                                                     Height="20"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Name="vaultTXT" Text="Vaults" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Name="appListVI"
                                  Style="{StaticResource NavItemStyle}"
                                  ToolTip="Applications"
                                  PreviewMouseDown="App_PreviewMouseDown"
                                  IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Name="appIcon"
                                                     Kind="KeyVariant"
                                                     Tag="PreserveThemeForeground"
                                                     Foreground="{DynamicResource SidebarNavDisabledTextBrush}"
                                                     Width="20"
                                                     Height="20"
                                                     Margin="0,0,12,0"/>
                            <TextBlock x:Name="appTXT" Text="Applications" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ListViewItem>
                    <ListViewItem Name="settingsListVI"
                                  Style="{StaticResource NavItemStyle}"
                                  ToolTip="Settings"
                                  PreviewMouseDown="Settings_PreviewMouseDown">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Name="settingIcon"
                                                     Kind="TuneVariant"
                                                     Tag="PreserveThemeForeground"
                                                     Foreground="{DynamicResource SidebarNavTextBrush}"
                                                     Width="20"
                                                     Height="20"
                                                     Margin="0,0,12,0"/>
                            <TextBlock Name="settingsTXT" Text="Settings" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </ListViewItem>
                </StackPanel>

                <Border Grid.Row="3"
                        Margin="12,0,12,14"
                        Padding="12,10"
                        Background="{DynamicResource SidebarUserCardBrush}"
                        CornerRadius="10"
                        BorderBrush="{DynamicResource SidebarUserCardBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="32" Height="32"
                                Background="#4F46E5"
                                CornerRadius="16"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountOutline"
                                                     Width="17" Height="17"
                                                     Foreground="White"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Name="userTXB"
                                       Text="user"
                                       Foreground="{DynamicResource SidebarUserPrimaryBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Name="userTypeTXB"
                                       Text="Local user"
                                       Foreground="{DynamicResource SidebarUserSecondaryBrush}"
                                       FontSize="10"
                                       Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                            <TextBlock Name="vaultExpireTb"
                                       Visibility="Hidden"
                                       Text="Vault Expire"
                                       Foreground="#FBBF24"
                                       Background="Transparent"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                            <materialDesign:PackIcon Name="vaultElapsed"
                                                     Visibility="Hidden"
                                                     Foreground="#FBBF24"
                                                     Kind="AlertCircleOutline"
                                                     Width="16"
                                                     Height="16"
                                                     HorizontalAlignment="Right"
                                                     Margin="0,-18,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4"
                           Name="versionLabel"
                           Text="v1.0"
                           Foreground="{DynamicResource SidebarVersionTextBrush}"
                           FontSize="10"
                           Margin="18,6,0,10"
                           HorizontalAlignment="Left"/>
            </Grid>
            </Border>

            <Border Grid.Column="1"
                    CornerRadius="0,16,0,0"
                    Background="{DynamicResource SurfaceBrush}"
                    SizeChanged="RoundedBorder_SizeChanged">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="28,13,0,0">
                    <TextBlock Text="Password Manager" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold"/>
                    <TextBlock Text="Secure, local credential storage" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,14,16,0">
                    <Border Width="36" Height="36" Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,8,0">
                        <Label Name="miniMizeLBL"
                               Content="−"
                               PreviewMouseDown="minimizeLBL_PreviewMouseDown"
                               FontSize="20"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Padding="0,-7,0,0"
                               Cursor="Hand"/>
                    </Border>
                    <materialDesign:PopupBox Foreground="{DynamicResource TextSecondaryBrush}"
                                             PlacementMode="BottomAndAlignRightEdges"
                                             StaysOpen="False"
                                             Width="36"
                                             Height="36"
                                             Padding="6">
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SurfaceBrush}">
                            <StackPanel Width="150">
                                <Button Content="About"
                                        Style="{StaticResource PopupMenuButtonStyle}"
                                        Padding="14,10"
                                        HorizontalContentAlignment="Left"
                                        Click="aboutBTN_Click"/>
                                <Separator Margin="8,0"/>
                                <Button Content="Exit"
                                        Style="{StaticResource PopupDangerButtonStyle}"
                                        Padding="14,10"
                                        HorizontalContentAlignment="Left"
                                        Click="closeBTN_Click"/>
                            </StackPanel>
                        </Border>
                    </materialDesign:PopupBox>
                </StackPanel>
                <Border Grid.ColumnSpan="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"/>
            </Grid>
            </Border>

            <Border Grid.Column="1"
                    Grid.Row="1"
                    Background="{DynamicResource AppBackgroundBrush}"
                    CornerRadius="0,0,16,0"
                    SizeChanged="RoundedBorder_SizeChanged">
            <TabControl Name="tabControl"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="28,24">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <TabItem Name="vaultTab" Header="Vaults">
                    <Grid Background="{DynamicResource AppBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Your vaults" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold"/>
                                <TextBlock Text="Open a vault to view and manage its saved credentials." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource AccentSurfaceBrush}" CornerRadius="9" Padding="12,8" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Name="vaultStorageIcon" Kind="ShieldOutline" Foreground="#4F46E5" Width="18" Height="18" Margin="0,0,7,0"/>
                                    <TextBlock Name="vaultStorageLabel" Text="Select a vault" Foreground="{DynamicResource AccentTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                SizeChanged="RoundedListBorder_SizeChanged">
                            <ListView Name="vaultList"
                                      Style="{StaticResource DataListStyle}"
                                      Margin="8,8,8,0"
                                      PreviewMouseDoubleClick="vaultList_PreviewMouseDoubleClick"
                                      SelectionChanged="vaultList_SelectionChanged"
                                      KeyDown="vaultList_KeyDown">
                                <ListView.View>
                                    <GridView ColumnHeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle1}">
                                        <GridViewColumn Header="Vault name" Width="225" DisplayMemberBinding="{Binding Name}"/>
                                        <GridViewColumn Header="Storage" Width="150" DisplayMemberBinding="{Binding Storage}"/>
                                        <GridViewColumn Header="Created" Width="205" DisplayMemberBinding="{Binding CreateDate}"/>
                                        <GridViewColumn Header="Location" Width="210" DisplayMemberBinding="{Binding SharePoint}"/>
                                    </GridView>
                                </ListView.View>
                                <ListView.ContextMenu>
                                    <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                        <MenuItem Header="Export vault" Click="ExportVault_Click" Tag="2" Style="{StaticResource ModernMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="Export"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Change master password" Click="ChangeMasterPassword_Click" Tag="2" Style="{StaticResource ModernMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="LockReset"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator Style="{StaticResource ModernMenuSeparatorStyle}"/>
                                        <MenuItem Header="Delete or remove vault" Click="DeleteVault_Click" Tag="2" Style="{StaticResource ModernDangerMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="DeleteOutline"/></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </Border>

                        <StackPanel Grid.Row="4" Orientation="Horizontal">
                            <Border Style="{StaticResource IconActionBorderStyle}" PreviewMouseDown="AddVaultIcon_PreviewMouseDown" ToolTip="Add Vault">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Name="AddVaultIcon" Kind="Plus" Foreground="#4F46E5" Width="17" Height="17" Margin="0,0,7,0"/>
                                    <TextBlock Text="New vault" Foreground="#334155" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource IconActionBorderStyle}" PreviewMouseDown="ImportVaultIcon_PreviewMouseDown" ToolTip="Import Vault">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Name="ImportVaultIcon" Kind="Import" Foreground="#4F46E5" Width="17" Height="17" Margin="0,0,7,0"/>
                                    <TextBlock Text="Import" Foreground="#334155" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource IconActionBorderStyle}" PreviewMouseDown="DelVaultIcon_PreviewMouseDown" ToolTip="Delete or remove vault">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Name="DelVaultIcon" Kind="DeleteOutline" Foreground="#DC2626" Width="17" Height="17" Margin="0,0,7,0"/>
                                    <TextBlock Text="Remove" Foreground="#991B1B" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Name="appTab" Header="Applications">
                    <Grid Background="{DynamicResource AppBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Saved credentials" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Entries in " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"/>
                                    <TextBlock Name="appListVaultLVL" Text="vault" Foreground="#4F46E5" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="LockCheckOutline" Foreground="#16A34A" Width="18" Height="18" Margin="0,0,7,0"/>
                                <TextBlock Text="Vault unlocked" Foreground="{DynamicResource SuccessTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                SizeChanged="RoundedListBorder_SizeChanged">
                            <ListView Name="appList"
                                      Style="{StaticResource DataListStyle}"
                                      Margin="8,8,8,0"
                                      GridViewColumnHeader.Click="AppListColumnHeaderClickedHandler">
                                <ListView.View>
                                    <GridView ColumnHeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle1}">
                                        <GridViewColumn Header="Application" Width="260" DisplayMemberBinding="{Binding Application}"/>
                                        <GridViewColumn Header="Account" Width="260" DisplayMemberBinding="{Binding Account}"/>
                                        <GridViewColumn Header="Password" Width="270" DisplayMemberBinding="{Binding Password}"/>
                                    </GridView>
                                </ListView.View>
                                <ListView.ContextMenu>
                                    <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                        <MenuItem Header="Copy password for 15 seconds" Click="CopyToClipboard_Click" Tag="1" Style="{StaticResource ModernMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="ContentCopy"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Show password" Click="ShowPassword_Click" Tag="2" Style="{StaticResource ModernMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="EyeOutline"/></MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Update account password" Click="UpdateAccountPass_Click" Tag="2" Style="{StaticResource ModernMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="LockReset"/></MenuItem.Icon>
                                        </MenuItem>
                                        <Separator Style="{StaticResource ModernMenuSeparatorStyle}"/>
                                        <MenuItem Header="Delete account" Click="DeleteAccount_Click" Tag="2" Style="{StaticResource ModernDangerMenuItemStyle}">
                                            <MenuItem.Icon><materialDesign:PackIcon Kind="DeleteOutline"/></MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                            </ListView>
                        </Border>

                        <Grid Grid.Row="4">
                            <StackPanel Orientation="Horizontal">
                                <Border Style="{StaticResource IconActionBorderStyle}" PreviewMouseDown="AddAppIcon_PreviewMouseDown" ToolTip="Add Application">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Name="AddAppIcon" Kind="Plus" Foreground="#4F46E5" Width="17" Height="17" Margin="0,0,7,0"/>
                                        <TextBlock Text="New credential" Foreground="#334155" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource IconActionBorderStyle}" PreviewMouseDown="DelAppIcon_PreviewMouseDown" ToolTip="Delete Application">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon x:Name="DelApp" Kind="DeleteOutline" Foreground="#DC2626" Width="17" Height="17" Margin="0,0,7,0"/>
                                        <TextBlock Text="Delete" Foreground="#991B1B" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <materialDesign:PackIcon Kind="Logout" Name="logoutIconV" Width="18" Height="18" Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Button Name="vaultCloseLBL"
                                        Style="{DynamicResource ExitVaultButton}"
                                        Content="Lock vault"
                                        Click="vaultCloseLBL_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Name="settingsTab" Header="Settings">
                    <Grid Background="{DynamicResource AppBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Page title -->
                        <StackPanel>
                            <TextBlock Text="Settings" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="Configure appearance and how PwM protects active vault sessions." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Scrollable cards -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,6,0">
                            <StackPanel>

                                <!-- Appearance card -->
                                <Border Width="520"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="22">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="18"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="38" Height="38" Background="{DynamicResource AccentSurfaceBrush}" CornerRadius="9">
                                                <materialDesign:PackIcon Kind="ThemeLightDark"
                                                                         Width="20" Height="20"
                                                                         Foreground="{DynamicResource AccentBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Appearance" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Choose the desktop theme. The selection is saved and applied to all PwM windows."
                                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="Theme" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="themeModeComboBox"
                                                      Style="{StaticResource SettingsComboBoxStyle}"
                                                      Width="180"
                                                      HorizontalAlignment="Left"
                                                      SelectionChanged="themeModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Light" Tag="Light"/>
                                                <ComboBoxItem Content="Dark" Tag="Dark"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Height="16"/>

                                <!-- Vault session timeout card -->
                                <Border Width="520"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="22">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="18"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="38" Height="38" Background="{DynamicResource AccentSurfaceBrush}" CornerRadius="9">
                                                <materialDesign:PackIcon Kind="TimerLockOutline"
                                                                         Width="20" Height="20"
                                                                         Foreground="#4F46E5"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Vault session timeout" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Automatically lock an inactive vault after this period. Default: 10 minutes."
                                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Input row -->
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Expire after (minutes)" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBox x:Name="expirePeriodTxT"
                                                         Style="{StaticResource SettingsInputStyle}"
                                                         Width="180"
                                                         HorizontalAlignment="Left"
                                                         TextAlignment="Left"
                                                         adorners:Watermark.Text="10">
                                                    <adorners:Watermark.TextStyle>
                                                        <Style TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Margin" Value="12,0,0,0"/>
                                                        </Style>
                                                    </adorners:Watermark.TextStyle>
                                                </TextBox>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Name="applyExpirePeriodBTN"
                                                    Style="{DynamicResource RoundCorner2}"
                                                    Content="Apply"
                                                    Click="applyExpirePeriodBTN_Click"
                                                    IsEnabled="True"
                                                    IsDefault="True"
                                                    VerticalAlignment="Bottom"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Spacer -->
                                <Border Height="16"/>

                                <!-- Argon2 hashing parameters card -->
                                <Border Width="520"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="22"
                                        Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="18"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="42"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="38" Height="38" Background="{DynamicResource AccentSurfaceBrush}" CornerRadius="9">
                                                <materialDesign:PackIcon Kind="ShieldLockOutline"
                                                                         Width="20" Height="20"
                                                                         Foreground="#4F46E5"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock Text="Argon2 hashing parameters" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBlock Text="Controls how the master password is derived into an encryption key. Higher values increase security but also login time."
                                                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Iterations -->
                                        <StackPanel Grid.Row="2">
                                            <TextBlock Foreground="#475569" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4">
                                                <Run Text="Iterations "/>
                                                <Run Text="(time cost, 10–200)" Foreground="#94A3B8" FontSize="11" FontWeight="Normal"/>
                                            </TextBlock>
                                            <TextBlock Text="Number of passes over memory. Default: 40."
                                                       Foreground="#94A3B8" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBox x:Name="argon2IterationsTxt"
                                                     Style="{StaticResource SettingsInputStyle}"
                                                     Width="180"
                                                     HorizontalAlignment="Left"
                                                     TextAlignment="Left"
                                                     adorners:Watermark.Text="40">
                                                <adorners:Watermark.TextStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Margin" Value="12,0,0,0"/>
                                                    </Style>
                                                </adorners:Watermark.TextStyle>
                                            </TextBox>
                                        </StackPanel>

                                        <!-- Memory size -->
                                        <StackPanel Grid.Row="4">
                                            <TextBlock Foreground="#475569" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4">
                                                <Run Text="Memory size "/>
                                                <Run Text="(KB, 4096–1 048 576)" Foreground="#94A3B8" FontSize="11" FontWeight="Normal"/>
                                            </TextBlock>
                                            <TextBlock Text="RAM used per hash in kilobytes. Default: 4096 KB (4 MB)."
                                                       Foreground="#94A3B8" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBox x:Name="argon2MemorySizeTxt"
                                                     Style="{StaticResource SettingsInputStyle}"
                                                     Width="180"
                                                     HorizontalAlignment="Left"
                                                     TextAlignment="Left"
                                                     adorners:Watermark.Text="4096">
                                                <adorners:Watermark.TextStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Margin" Value="12,0,0,0"/>
                                                    </Style>
                                                </adorners:Watermark.TextStyle>
                                            </TextBox>
                                        </StackPanel>

                                        <!-- Parallelism -->
                                        <StackPanel Grid.Row="6">
                                            <TextBlock Foreground="#475569" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4">
                                                <Run Text="Parallelism "/>
                                                <Run Text="(threads, 1–16)" Foreground="#94A3B8" FontSize="11" FontWeight="Normal"/>
                                            </TextBlock>
                                            <TextBlock Text="Number of parallel threads used during hashing. Default: 2."
                                                       Foreground="#94A3B8" FontSize="11" Margin="0,0,0,6"/>
                                            <TextBox x:Name="argon2ParallelismTxt"
                                                     Style="{StaticResource SettingsInputStyle}"
                                                     Width="180"
                                                     HorizontalAlignment="Left"
                                                     TextAlignment="Left"
                                                     adorners:Watermark.Text="2">
                                                <adorners:Watermark.TextStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Opacity" Value="0.5"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                        <Setter Property="Margin" Value="12,0,0,0"/>
                                                    </Style>
                                                </adorners:Watermark.TextStyle>
                                            </TextBox>
                                        </StackPanel>

                                        <!-- Warning -->
                                        <Border Grid.Row="8"
                                                Background="{DynamicResource WarningSurfaceBrush}"
                                                BorderBrush="{DynamicResource WarningBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10,8">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="AlertOutline"
                                                                         Foreground="#EA580C"
                                                                         Width="16" Height="16"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="Changing these settings affects all vaults. Re-create vaults after applying."
                                                           Foreground="{DynamicResource WarningTextBrush}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Apply -->
                                        <Grid Grid.Row="10">
                                            <Button Name="applyArgon2SettingsBTN"
                                                    Style="{DynamicResource RoundCorner2}"
                                                    Content="Apply"
                                                    Width="90"
                                                    Height="38"
                                                    HorizontalAlignment="Right"
                                                    Click="applyArgon2SettingsBTN_Click"/>
                                        </Grid>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
            </Border>
        </Grid>
    </Border>
</Window>
