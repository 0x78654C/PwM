<Window x:Class="PwM.MasterPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:adorners="http://gu.se/Adorners"
        mc:Ignorable="d"
        Title="PwM - Password Manager"
        Name="MasterPasswordWPF"
        Icon="pack://application:,,,/Resources/logo-modern.ico"
        AllowsTransparency="True"
        Background="Transparent"
        Height="300"
        Width="440"
        ResizeMode="NoResize"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        WindowStartupLocation="CenterScreen">
    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#0F172A" CornerRadius="13,13,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" Background="#4F46E5" CornerRadius="9" HorizontalAlignment="Right">
                        <materialDesign:PackIcon Kind="ShieldLock"
                                                 Width="19"
                                                 Height="19"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,14,0,0">
                        <TextBlock Text="Unlock vault" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Enter your master password to continue" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="2"
                                             Name="vaultIcon"
                                             Foreground="#CBD5E1"
                                             PreviewMouseDown="closeLBL_PreviewMouseDown"
                                             Kind="Close"
                                             Width="20"
                                             Height="20"
                                             Cursor="Hand"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,20,24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="9" Padding="12,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="SafeSquareOutline" Width="18" Height="18" Foreground="#4F46E5" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Name="vaultNameLBL" Text="name" Foreground="#0F172A" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Grid.Column="2" Background="#EEF2FF" CornerRadius="7" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Name="vaultTypeIcon" Kind="Harddisk" Foreground="#4F46E5" Width="14" Height="14" Margin="0,0,5,0"/>
                                <TextBlock Name="vaultTypeLBL" Text="Local vault" Foreground="#4338CA" FontSize="10" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox Name="masterPasswordPWD"
                                 Height="42"
                                 Background="White"
                                 BorderBrush="#CBD5E1"
                                 BorderThickness="1"
                                 Foreground="#0F172A"
                                 FontSize="15"
                                 Padding="12,0"
                                 VerticalContentAlignment="Center"
                                 adorners:Watermark.Text="Master password">
                        <adorners:Watermark.TextStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="12,0,0,0"/>
                            </Style>
                        </adorners:Watermark.TextStyle>
                    </PasswordBox>
                    <TextBox Name="ShowMasterPassword"
                             Visibility="Hidden"
                             Height="42"
                             Background="White"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"
                             Foreground="#0F172A"
                             FontSize="15"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             adorners:Watermark.Text="Master password">
                        <adorners:Watermark.TextStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="12,0,0,0"/>
                            </Style>
                        </adorners:Watermark.TextStyle>
                    </TextBox>
                    <materialDesign:PackIcon Grid.Column="1"
                                             Name="ShowPassword"
                                             ToolTip="Hold right click to show password"
                                             Foreground="#64748B"
                                             Kind="EyeOutline"
                                             Width="18"
                                             Height="18"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Center"
                                             Cursor="Hand"
                                             PreviewMouseRightButtonDown="ShowHideMasterPassword"
                                             PreviewMouseRightButtonUp="ShowHideMasterPassword"
                                             PreviewMouseMove="ShowPassword_PreviewMouseMove"/>
                </Grid>

                <Grid Grid.Row="4">
                    <TextBlock Text="Your password never leaves this device." Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                    <Button Name="confirmBTN"
                            Style="{DynamicResource RoundCorner2}"
                            Content="Unlock"
                            Width="104"
                            Height="38"
                            HorizontalAlignment="Right"
                            Click="confirmBTN_Click"
                            IsDefault="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
