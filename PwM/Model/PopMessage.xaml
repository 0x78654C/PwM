<Window x:Class="PwM.PopMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PwM - Password Manager"
        Icon="pack://application:,,,/Resources/logo-modern.ico"
        AllowsTransparency="True"
        Background="Transparent"
        Height="290" Width="440"
        ResizeMode="NoResize" WindowStyle="None"
        WindowStartupLocation="CenterScreen" Topmost="True">
    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/></Border.Effect>
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Name="popGrid" Background="#0F172A" CornerRadius="13,13,0,0">
                <Grid>
                    <Image Source="pack://application:,,,/Resources/logo-modern.png" Width="38" Height="38" Margin="18,0,0,0" HorizontalAlignment="Left"/>
                    <TextBlock Name="titleTxt" Text="Notification" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="68,0,0,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="24,20,24,20">
                <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Name="statusIconBorder" Width="42" Height="42" Background="#EEF2FF" CornerRadius="10" Margin="0,0,14,0">
                        <materialDesign:PackIcon Name="statusIcon" Kind="InformationOutline" Foreground="#4F46E5" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Name="notificationLBL" Text="notificationArea" Foreground="#334155" FontSize="13" TextWrapping="Wrap" Width="320" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Row="1" Name="confirmBTN" Style="{DynamicResource RoundCorner2}" Content="OK" Width="96" Height="38" HorizontalAlignment="Right" Click="confirmBTN_Click" IsDefault="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
