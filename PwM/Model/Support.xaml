<Window x:Class="PwM.Support" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PwM - Password Manager" Icon="pack://application:,,,/Resources/logo-modern.ico" AllowsTransparency="True" Background="Transparent" Height="430" Width="590" ResizeMode="NoResize" WindowStyle="None" WindowStartupLocation="CenterScreen">
    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1"><Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/></Border.Effect>
        <Grid><Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="#0F172A" CornerRadius="13,13,0,0"><Grid><Image Source="pack://application:,,,/Resources/logo-modern.png" Width="44" Height="44" Margin="18,0,0,0" HorizontalAlignment="Left"/><StackPanel Margin="74,15,0,0"><TextBlock Text="Support PwM" Foreground="White" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Help support continued development" Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0"/></StackPanel></Grid></Border>
            <Grid Grid.Row="1" Margin="28,20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="14"/><RowDefinition Height="Auto"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Name="notificationLBL" Text="If you like this application and want to support the project, you can contribute using one of the addresses below." Foreground="#475569" FontSize="12" TextWrapping="Wrap"/>
                <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="9" Padding="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><materialDesign:PackIcon x:Name="CryptoCoffeIconBit" Kind="Bitcoin" Foreground="#F59E0B" Width="20" Height="20"/><TextBox Grid.Column="1" Name="BitCoinTextBox" Text="bc1qe6z79u5f62c3v5lh6nt3hfcj683etyx65s5nch" Background="Transparent" BorderThickness="0" IsReadOnly="True" Foreground="#334155" FontSize="11"/><materialDesign:PackIcon Grid.Column="2" Name="BitCopyIcon" Kind="ContentCopy" Foreground="#4F46E5" Width="18" Height="18"/><Label Grid.Column="2" Name="BitCopyLbl" Background="Transparent" Cursor="Hand" PreviewMouseDown="BitCopyLbl_PreviewMouseDown"/></Grid></Border>
                <Border Grid.Row="4" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="9" Padding="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions><materialDesign:PackIcon x:Name="CryptoCoffeIconEth" Kind="Ethereum" Foreground="#6366F1" Width="20" Height="20"/><TextBox Grid.Column="1" Name="EthereumTextBox" Text="0x7Aedd83d94b350624f4FDb4dF7eC3a2A7caA9952" Background="Transparent" BorderThickness="0" IsReadOnly="True" Foreground="#334155" FontSize="11"/><materialDesign:PackIcon Grid.Column="2" Name="EthCopyIcon" Kind="ContentCopy" Foreground="#4F46E5" Width="18" Height="18"/><Label Grid.Column="2" Name="EthCopyLbl" Background="Transparent" Cursor="Hand" PreviewMouseDown="EthCopyLbl_PreviewMouseDown"/></Grid></Border>
                <Grid Grid.Row="6"><Label Name="HashCopyResultLbl" Content=" " Foreground="#16A34A" FontSize="11" Padding="0" VerticalAlignment="Center"/><Button Name="Close_Button" Style="{DynamicResource RoundCorner2}" Content="Close" Width="96" Height="38" HorizontalAlignment="Right" IsDefault="True" Click="Close_Button_Click"/></Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
