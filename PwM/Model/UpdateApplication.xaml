<Window x:Class="PwM.UpdateApplication"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:adorners="http://gu.se/Adorners"
        Title="PwM - Password Manager"
        Name="UpdateApplicationWPF"
        Icon="pack://application:,,,/Resources/logo-modern.ico"
        AllowsTransparency="True"
        Background="Transparent"
        Height="390"
        Width="440"
        ResizeMode="NoResize"
        WindowStyle="None"
        MouseDown="Window_MouseDown"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CredentialInputStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="CredentialPasswordStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#0F172A" CornerRadius="13,13,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="54"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="46"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="34" Height="34" Background="#4F46E5" CornerRadius="9" HorizontalAlignment="Right">
                        <materialDesign:PackIcon Kind="LockReset"
                                                 Width="19"
                                                 Height="19"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,14,0,0">
                        <TextBlock Text="Update password" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Text="Replace the password for this credential" Foreground="#94A3B8" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <materialDesign:PackIcon Grid.Column="2"
                                             Kind="Close"
                                             Width="20"
                                             Height="20"
                                             Foreground="#CBD5E1"
                                             Cursor="Hand"
                                             ToolTip="Close"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             PreviewMouseDown="closeLBL_PreviewMouseDown"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="9" Padding="12,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Application" Foreground="#64748B" FontSize="10"/>
                            <TextBlock Name="ApplicationNameTXT" Text="application" Foreground="#0F172A" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Account" Foreground="#64748B" FontSize="10"/>
                            <TextBlock Name="AccountNameTXT" Text="account" Foreground="#0F172A" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0"/>
                        </StackPanel>
                        <TextBlock Name="ApplicationTXT" Visibility="Collapsed"/>
                        <TextBlock Name="AccountTXT" Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="New password" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Name="newPassAccBox"
                                     Style="{StaticResource CredentialPasswordStyle}"
                                     PasswordChanged="newPassAccBox_PasswordChanged"
                                     adorners:Watermark.Text="Enter the new account password">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </PasswordBox>
                        <TextBox Name="NewPasswordShow"
                                 Style="{StaticResource CredentialInputStyle}"
                                 Visibility="Hidden"
                                 adorners:Watermark.Text="Enter the new account password">
                            <adorners:Watermark.TextStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Opacity" Value="0.45"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="12,0,0,0"/>
                                </Style>
                            </adorners:Watermark.TextStyle>
                        </TextBox>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <materialDesign:PackIcon Name="GenerateNewPassAcc"
                                                     Kind="AutoFix"
                                                     Foreground="#4F46E5"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,0,14,0"
                                                     Cursor="Hand"
                                                     ToolTip="Generate strong password"
                                                     PreviewMouseDown="GenerateNewPassAcc_PreviewMouseDown"/>
                            <materialDesign:PackIcon Name="ShowNewPassword"
                                                     Kind="EyeOutline"
                                                     Foreground="#64748B"
                                                     Width="18"
                                                     Height="18"
                                                     Cursor="Hand"
                                                     ToolTip="Hold right click to show password"
                                                     PreviewMouseRightButtonDown="ShowHideNewPassword"
                                                     PreviewMouseRightButtonUp="ShowHideNewPassword"
                                                     PreviewMouseMove="ShowNewPassword_PreviewMouseMove"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Grid.Row="3" Margin="0,10,0,0" Background="#FEF2F2" CornerRadius="7" Padding="10,7">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Visibility, ElementName=breachLbl}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="#DC2626" Width="16" Height="16" Margin="0,0,7,0"/>
                        <TextBlock Name="breachLbl"
                                   Visibility="Hidden"
                                   Text="This password appears in an exposed data breach."
                                   Foreground="#B91C1C"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="5">
                    <TextBlock Text="The credential remains encrypted in your vault." Foreground="#94A3B8" FontSize="10" VerticalAlignment="Center"/>
                    <Button Name="updateAccPassBTN"
                            Style="{DynamicResource RoundCorner2}"
                            Content="Update password"
                            MinWidth="132"
                            Height="38"
                            HorizontalAlignment="Right"
                            IsEnabled="False"
                            Click="updateAccPassBTN_Click"
                            IsDefault="True"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
