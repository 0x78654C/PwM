<Window x:Class="PwM.about" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="About PwM" Icon="pack://application:,,,/Resources/logo-modern.ico" AllowsTransparency="True" Background="Transparent" Height="500" Width="600" ResizeMode="NoResize" WindowStyle="None" MouseDown="Window_MouseDown" WindowStartupLocation="CenterScreen">
    <Border Margin="10" Background="White" CornerRadius="14" BorderBrush="#E2E8F0" BorderThickness="1"><Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.2" Color="#0F172A"/></Border.Effect>
        <Grid><Grid.RowDefinitions><RowDefinition Height="76"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="#0F172A" CornerRadius="13,13,0,0">
                <Grid>
                    <Image Source="pack://application:,,,/Resources/logo-modern.png" Width="46" Height="46" Margin="18,0,0,0" HorizontalAlignment="Left"/>
                    <StackPanel Margin="76,15,0,0">
                        <TextBlock Text="About PwM" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                        <TextBlock Text="Private, local password management" Foreground="#94A3B8" FontSize="11" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Border Style="{DynamicResource TitleBarButtonBorder}"
                            HorizontalAlignment="Right"
                            Margin="0,0,18,0"
                            ToolTip="Minimize"
                            PreviewMouseDown="minimizeLBL_PreviewMouseDown">
                        <Label Name="miniMizeLBL"
                               Content="−"
                               Foreground="{DynamicResource TitleBarButtonForegroundBrush}"
                               FontSize="20"
                               IsHitTestVisible="False"
                               HorizontalContentAlignment="Center"
                               VerticalContentAlignment="Center"
                               Padding="0,-7,0,0"/>
                    </Border>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="28,22"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="16"/><RowDefinition Height="*"/><RowDefinition Height="16"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><Label Name="assamblyNameLBL" Content="Name" Foreground="#0F172A" FontSize="14" FontWeight="SemiBold" Padding="0"/><Label Name="versionNameLBL" Content="Version" Foreground="#64748B" FontSize="11" Padding="0" Margin="0,6,0,0"/><Label Name="copyRightLBL" Content="Copyright" Foreground="#94A3B8" FontSize="10" Padding="0" Margin="0,6,0,0"/></StackPanel><Border Grid.Column="1" Background="#EEF2FF" CornerRadius="10" Padding="14" HorizontalAlignment="Right"><materialDesign:PackIcon Kind="ShieldLockOutline" Foreground="#4F46E5" Width="42" Height="42"/></Border></Grid>
                <TextBox Grid.Row="2" Name="descriptionTXT" Text="Description" IsReadOnly="True" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Foreground="#475569" FontSize="12" TextWrapping="Wrap" Padding="14"/>
                <Grid Grid.Row="4"><StackPanel Orientation="Horizontal"><materialDesign:PackIcon x:Name="EmailContactIcon" Kind="EmailOutline" Foreground="#4F46E5" Width="19" Height="19" Margin="0,0,7,0"/><TextBox Name="EmailContactTxtBox" Text="xcoding.dev@gmail.com" BorderThickness="0" Background="Transparent" IsReadOnly="True" Foreground="#475569" FontSize="11"/><Image Name="BuyMeACoffe_Image" Visibility="Hidden" PreviewMouseDown="BuyMeACoffee_Image_PreviewMouseDown"/><materialDesign:PackIcon x:Name="CryptoCoffeIcon" Visibility="Hidden" PreviewMouseDown="BuyMeACoffee_Image_PreviewMouseDown"/></StackPanel><Button Name="closeBTNMSG" Style="{DynamicResource RoundCorner2}" Content="Close" Width="96" Height="38" HorizontalAlignment="Right" Click="closeBTNMSG_Click"/></Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
